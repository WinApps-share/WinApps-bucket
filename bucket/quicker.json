{
    "version": "1.45.2.0",
    "description": "指尖工具箱, Windows 效率工具",
    "homepage": "https://getquicker.net",
    "license": "Shareware",
    "architecture": {
        "64bit": {
            "url": "https://download.getquicker.net/_productfiles/202604/Quicker.x64.1.45.2.0.msi",
            "hash": "15f0ec7bdf88ab643c88c90d787531817d465de1cc5d1ab5c13cfda33dd35b64"
        },
        "32bit": {
            "url": "https://download.getquicker.net/_productfiles/202604/Quicker.x86.1.45.2.0.msi",
            "hash": "ce116f3897fa3b298574d093033e9e4e27c1b2bf9cd915834c1e025e9dd85d63"
        }
    },
    "extract_dir": "Quicker",
    "shortcuts": [
        [
            "Quicker.exe",
            "Quicker"
        ]
    ],
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "persist_file -dir @(\"$user_LocalAppData\\Quicker\",\"$user_Documents\\Quicker\") @(\"$persist_dir\\Quicker\",\"$persist_dir\\Quicker_Documents\")",
        "handle_app_lnk",
        "do_some_things"
    ],
    "pre_uninstall": [
        "$bucket = (Get-Content \"$dir\\install.json\" | ConvertFrom-Json).bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "stop_process",
        "remove_files @(\"$user_Documents\\Quicker\",\"$user_LocalAppData\\Quicker\")"
    ],
    "checkver": {
        "url": "https://getquicker.net/open/api/quicker/versionhistory",
        "regex": "productfiles%2F([\\d]+)%2FQuicker\\.x64\\.([\\d.]+)\\.msi",
        "replace": "$2"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.getquicker.net/_productfiles/$match1/Quicker.x64.$version.msi"
            },
            "32bit": {
                "url": "https://download.getquicker.net/_productfiles/$match1/Quicker.x86.$version.msi"
            }
        }
    }
}
